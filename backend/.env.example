NODE_ENV=development
PORT=4000

# Using Neon (or any PgBouncer-fronted Postgres)? DATABASE_URL should be the
# pooled ("-pooler") connection string for app queries; DIRECT_URL is the
# unpooled one, used only by `prisma migrate` (PgBouncer's transaction
# pooling mode doesn't support the prepared statements migrations need).
# sslmode=require is mandatory for Neon. Keep connection_limit above 1 —
# the search worker runs in the same process as the API (see server.ts)
# and needs headroom to query concurrently with request handling, or
# they'll contend for the single connection and time out under load.
DATABASE_URL=postgresql://user:password@ep-example-pooler.us-east-2.aws.neon.tech/reachiq?sslmode=require&pgbouncer=true&connection_limit=10
DIRECT_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/reachiq?sslmode=require

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# AES-256-GCM key for encrypting user BYOK OpenAI keys at rest. 32 bytes, base64-encoded.
ENCRYPTION_KEY_BASE64=

ZEROBOUNCE_API_KEY=

SCRAPE_DELAY_MIN_MS=1500
SCRAPE_DELAY_MAX_MS=4000

# Self-hosted SearXNG (search step, replaces scraping Google directly).
# Must have `json` under `search.formats` enabled in its settings.yml.
SEARXNG_URL=http://your-searxng-host:8080
# Public Overpass API (places/business step, replaces Google Maps). Free,
# no key — the public instance below is fine unless you're doing high volume.
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Free for now — reveals don't spend credits. Set back to 1+ to re-enable
# credit-gated reveals later; no code changes needed either way.
REVEAL_CREDIT_COST=0
