# Base URL of the ReachIQ backend (see ../backend). Point this at your
# Coolify-hosted deployment before building the APK — Expo inlines
# EXPO_PUBLIC_* vars into the JS bundle at build time, so it must be set
# *before* running `eas build`, not just at runtime.
EXPO_PUBLIC_API_URL=https://reachiq-api.yourdomain.com
